# Скопируйте в .env и заполните значения.
# Для Docker Compose: docker compose подхватывает .env из текущей директории.

# БД (опционально — по умолчанию используется контейнер postgres)
# DB_URL=jdbc:postgresql://postgres:5432/quizz
# DB_USERNAME=postgres
# DB_PASSWORD=postgres

# Почта (обязательно для входа по OTP)
MAIL_USERNAME=your-email@mail.ru
MAIL_PASSWORD=your-app-password

# JWT (опционально)
# JWT_SECRET=your-secret
# JWT_EXPIRATION=86400000
